# Ambiente da aplicacao: "development" ou "production"
# Em production, o CORS restringe origens apenas ao dominio de producao
# e o Uvicorn roda sem modo debug/reload.
APP_ENV=production

# Caminho para as credenciais do Firebase Admin SDK
FIREBASE_CREDENTIALS=credentials.json

# Origens permitidas no CORS em producao (separadas por virgula, se necessario customizar)
# Padrao: https://manu-frontend-beta.vercel.app
ALLOWED_ORIGINS=https://manu-frontend-beta.vercel.app
